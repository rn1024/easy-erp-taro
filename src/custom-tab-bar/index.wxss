.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60px;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -1px 6px rgba(0, 0, 0, 0.1);
  z-index: 9999;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-border {
  background-color: #F3F4F9;
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 1px;
  transform: scaleY(0.5);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
}

.tab-bar-icon {
  width: 24px;
  height: 24px;
  margin-bottom: 2px;
}

.tab-bar-text {
  font-size: 12px;
  line-height: 1;
  margin-top: 1px;
}

.create-item .create-button {
  width: 40px;
  height: 40px;
  background: linear-gradient(to right, #3b82f6, #07c160);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 6px rgba(59, 130, 246, 0.4);
}

.create-item .create-icon {
  width: 20px;
  height: 20px;
}
